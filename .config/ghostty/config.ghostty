window-decoration = none
font-size = 15.0
font-family = Pixel Code
font-family-bold = Pixel Code
font-family-italic = Pixel Code
font-family-bold-italic = Pixel Code
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
theme = main
cursor-style-blink = false
cursor-style = block
shell-integration-features = no-cursor
